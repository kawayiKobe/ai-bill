{
  "name": "ai-bill",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered billing app - React Native + NestJS",
  "workspaces": [
    "apps/mobile",
    "apps/server"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "server": "npm run start:dev --workspace=apps/server",
    "mobile:android": "npm run android --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "server:build": "npm run build --workspace=apps/server"
  },
  "devDependencies": {
    "@types/react": "^19.2.16"
  }
}
